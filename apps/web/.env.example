# IITJ One Website — copy to .env.local
#
# Same-origin proxy (recommended): Next.js rewrites /backend -> Express :6002.
# Used only by the anonymous support/feedback form (POST /suggestions) —
# this site does not display live campus data (see memory: project_not_open_source.md).
NEXT_PUBLIC_API_URL=/backend/api/v1

# Server-side only — where the /backend rewrite proxies to.
API_PROXY_TARGET=http://127.0.0.1:6002

# Canonical production URL, used for metadataBase / sitemap / OG tags.
# NOT confirmed yet — see plan's "Open items" list (iitjone.in vs iitjone.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Flip to real store URLs once published; leave empty for "Coming soon".
NEXT_PUBLIC_PLAY_STORE_URL=
NEXT_PUBLIC_APP_STORE_URL=
