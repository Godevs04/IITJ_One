# IITJ1 Admin Panel — copy to .env
#
# Same-origin proxy (recommended): Next.js rewrites /backend → Express :6002
# Avoids browser CORS / Cross-Origin-Resource-Policy issues.
NEXT_PUBLIC_API_URL=/backend/api/v1
NEXT_PUBLIC_CAMPUS_ID=iitj

# Where the Next.js rewrite proxies to (server-side only)
API_PROXY_TARGET=http://127.0.0.1:6002

# Direct URL alternative (not recommended for local browser admin):
# NEXT_PUBLIC_API_URL=http://localhost:6002/api/v1
