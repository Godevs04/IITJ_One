{
  "expo": {
    "name": "IITJ One",
    "slug": "iitj-one",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "iitj1",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D3F5E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.iitjone",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D3F5E"
      },
      "package": "app.iitjone",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "@react-native-firebase/perf",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D3F5E"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "IITJ One uses the camera so you can photograph your Mess QR code.",
          "photosPermission": "IITJ One uses your photo library so you can import your Mess QR code image."
        }
      ],
      "expo-sqlite",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "devPort": 6001,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c307eca8-e310-4cfa-aca6-8c06b8fcd39f"
      }
    },
    "owner": "godevs"
  }
}
