{
  "expo": {
    "name": "IITJ One",
    "slug": "iitj-one",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/logo.png",
    "scheme": "iitj1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "primaryColor": "#022543",
    "description": "Campus companion for IIT Jodhpur — mess menu, notices, transport, map, and more.",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/branding/marketing/ios-splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#022543"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "app.iitjone",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      },
      "splash": {
        "image": "./assets/branding/marketing/ios-splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#022543"
      }
    },
    "android": {
      "package": "app.iitjone",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/logo.png",
        "backgroundColor": "#022543"
      },
      "splash": {
        "image": "./assets/branding/marketing/android-splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#022543"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "./plugins/withFirebaseMessagingManifestFix.js",
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "@react-native-firebase/perf",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#022543",
          "resizeMode": "cover",
          "ios": {
            "image": "./assets/branding/marketing/ios-splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#022543",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "image": "./assets/branding/marketing/android-splash.png",
            "resizeMode": "cover",
            "backgroundColor": "#022543"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/notification-icon.png",
          "color": "#1D3F5E",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "IITJ One uses the camera so you can photograph your Mess QR code.",
          "photosPermission": "IITJ One uses your photo library so you can import your Mess QR code image.",
          "microphonePermission": false
        }
      ],
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "devPort": 6001,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c307eca8-e310-4cfa-aca6-8c06b8fcd39f"
      }
    },
    "owner": "godevs",
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#022543"
    }
  }
}
