# =============================================================================
# IITJ1 Mobile — Environment Configuration
# Copy to .env and fill in values.
# Expo Metro dev server runs on port 6001.
# API backend runs on port 6002.
# =============================================================================

# --- API ---
# Local development (simulator / emulator on same machine)
EXPO_PUBLIC_API_URL=http://localhost:6002/api/v1

# Physical device on same Wi-Fi — replace with your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:6002/api/v1

# Production build (EAS / store release)
# EXPO_PUBLIC_API_URL=https://api.iitjone.in/api/v1

# --- Campus ---
EXPO_PUBLIC_CAMPUS_ID=iitj

# --- App identity ---
EXPO_PUBLIC_APP_NAME=IITJ1
EXPO_PUBLIC_APP_SLUG=iitj1

# --- Dev server port (locked) ---
# Start with: npx expo start --port 6001
EXPO_PUBLIC_DEV_PORT=6001

# --- Firebase / Push notifications (FCM topics — no user accounts) ---
# Expo project ID (from expo.dev dashboard)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Firebase config (from Firebase console → Project settings → Your apps)
# Used for FCM topic subscription on Android/iOS
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:android:abcdef

# FCM topic prefix (must match API FCM_TOPIC_PREFIX)
EXPO_PUBLIC_FCM_TOPIC_PREFIX=iitj

# Default topics subscribed on first launch (comma-separated)
EXPO_PUBLIC_FCM_DEFAULT_TOPICS=iitj_all,iitj_mess,iitj_transport,iitj_institute,iitj_orientation

# --- Maps (Campus Map screen) ---
# Google Maps API key (Android) — enable Maps SDK for Android in Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Feature flags (optional) ---
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false

# --- Privacy / legal URLs (shown in Settings / About) ---
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://iitjone.in/privacy
EXPO_PUBLIC_DISCLAIMER=IITJ1 is a student-developed application for the IIT Jodhpur community. Not affiliated with or officially endorsed by IIT Jodhpur.

# =============================================================================
# Quick start
# =============================================================================
# 1. cp .env.example .env
# 2. Ensure API is running: cd ../api && PORT=6002 npm run dev
# 3. Start mobile:     npx expo start --port 6001
# 4. For physical device, set EXPO_PUBLIC_API_URL to your LAN IP (not localhost)
