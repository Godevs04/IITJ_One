{
  "_README": "Download the real google-services.json from Firebase Console",
  "_INSTRUCTIONS": [
    "1. Go to https://console.firebase.google.com/",
    "2. Select your project",
    "3. Go to Project Settings > General",
    "4. Under 'Your apps', select the Android app (app.iitjone)",
    "5. Download google-services.json",
    "6. Place it in apps/mobile/google-services.json",
    "7. Do NOT commit this file to git (it's in .gitignore)"
  ],
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_HASH",
        "android_client_info": {
          "package_name": "app.iitjone"
        }
      },
      "api_key": [
        {
          "current_key": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
