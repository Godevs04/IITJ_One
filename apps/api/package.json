{
  "name": "@iitj1/api",
  "version": "1.0.0",
  "private": true,
  "description": "IITJ One Express API — campus data for IIT Jodhpur",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node ../../scripts/set-lan-ip.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:render": "node ./scripts/render-build.cjs",
    "prestart": "node ./scripts/ensure-dist.cjs",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "test": "node --import tsx --test src/tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@iitj1/types": "*",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.12.0",
    "node-cache": "^5.1.2",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
