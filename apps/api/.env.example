# =============================================================================
# IITJ1 API — Environment Configuration
# Copy to .env and fill in values. API runs on port 6002 in local development.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=6002
NODE_ENV=development
# Public base URL — run: bash scripts/set-lan-ip.sh (auto-fills LAN IP)
API_BASE_URL=http://YOUR_LAN_IP:6002

# --- MongoDB ---
# Local: mongodb://localhost:27017/iitj1
# Production: MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/iitj1

# --- Campus ---
CAMPUS_ID=iitj

# --- JWT (admin auth only — no student accounts) ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Optional separate secret for refresh tokens (falls back to JWT_SECRET)
# JWT_REFRESH_SECRET=change-me-to-another-long-random-string-min-32
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated allowed origins for /admin/* routes.
# Auto-set by scripts/set-lan-ip.sh — includes Expo (6001) + admin (3000) on localhost + LAN.
# Example after running set-lan-ip.sh:
# CORS_ORIGIN=http://localhost:6001,http://192.168.1.33:6001,http://localhost:3000,http://192.168.1.33:3000
CORS_ORIGIN=http://localhost:6001,http://YOUR_LAN_IP:6001,http://localhost:3000,http://YOUR_LAN_IP:3000

# --- Rate limiting ---
RATE_LIMIT_PUBLIC_PER_MIN=120
RATE_LIMIT_ADMIN_LOGIN_MAX=5
RATE_LIMIT_ADMIN_LOGIN_WINDOW_MS=900000

# --- In-memory cache ---
CACHE_TTL_SECONDS=60

# --- Cloudinary (admin image uploads — signed upload, not through API body) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Folder prefix for uploaded assets
CLOUDINARY_UPLOAD_FOLDER=iitj1

# --- Firebase Cloud Messaging (topic-based push, no user records) ---
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Private key from Firebase service account JSON (escape newlines as \n)
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternative: path to service account JSON file (use one of FCM_PRIVATE_KEY or FCM_SERVICE_ACCOUNT_PATH)
FCM_SERVICE_ACCOUNT_PATH=

# FCM topic prefix (topics: iitj_all, iitj_mess, iitj_transport, iitj_institute, iitj_orientation)
FCM_TOPIC_PREFIX=iitj

# --- Admin bootstrap (seed script only — create first admin on first run) ---
ADMIN_BOOTSTRAP_EMAIL=admin@iitjone.in
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login
ADMIN_BOOTSTRAP_NAME=IITJ1 Admin

# --- Security ---
BCRYPT_ROUNDS=12

# --- ETag / caching headers ---
ENABLE_ETAG=true

# --- Logging ---
LOG_LEVEL=info

# --- Production overrides (uncomment for Render / api.iitjone.in) ---
# NODE_ENV=production
# API_BASE_URL=https://api.iitjone.in
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/iitj1
# CORS_ORIGIN=https://admin.iitjone.in
