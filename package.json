{
  "name": "iitj1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @iitj1/api",
    "dev:admin": "npm run dev -w @iitj1/admin",
    "dev:web": "npm run dev -w @iitj1/web",
    "dev:mobile": "npm run start -w @iitj1/mobile",
    "seed": "npm run seed -w @iitj1/api",
    "test:api": "npm run test -w @iitj1/api",
    "build:types": "npm run build -w @iitj1/types",
    "build:web": "npm run build -w @iitj1/web",
    "typecheck": "npm run typecheck -w @iitj1/types && npm run build -w @iitj1/types && npm run typecheck -w @iitj1/api && npm run typecheck -w @iitj1/admin && npm run typecheck -w @iitj1/web",
    "prepare": "npm run build -w @iitj1/types"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "use-sync-external-store": "^1.6.0"
  }
}
